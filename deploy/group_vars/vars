---

nginx_remove_default_vhost: true
nginx_vhosts:
  - listen: "443 ssl"
    server_name: "blackbassstudios.ca www.blackbassstudios.ca"
    access_log: "/var/log/nginx/access.log"
    filename: "blackbassstudios.ca.conf"
    extra_parameters: |
      location / {
          proxy_pass http://127.0.0.1:8080;
          proxy_set_header Host $host;
          proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
          proxy_set_header X-Forwarded-Host $host;
      }
      ssl_certificate     /etc/letsencrypt/live/blackbassstudios.ca/fullchain.pem;
      ssl_certificate_key /etc/letsencrypt/live/blackbassstudios.ca/privkey.pem;
  - listen: "80"
    server_name: "blackbassstudios.ca www.blackbassstudios.ca"
    return: "301 https://blackbassstudios.ca$request_uri"
    filename: "blackbassstudios.ca.80.conf"
